# Layer AI (lib/ai) — chiavi dei provider. Non committare il .env reale.
# Imposta queste nelle Environment Variables di Vercel quando colleghi davvero.

ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Immagini (lib/images, provider openai) — il tasto "Genera" in Fase 3.
# Senza questa chiave la fase resta in modalità manuale (Manus).
OPENAI_API_KEY=

# Persistenza (lib/store + lib/supabase) — Postgres + Storage + Auth.
# url + anon key: pubbliche per disegno (la sicurezza è nelle RLS), vanno nel client.
# Senza queste due lo store cade con grazia su EXAMPLE_STORY (deploy non si rompe).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service role: SOLO server-side (mai nel bundle né nei log). Riservata a M4
# (gen immagini server-side / percorso MCP). Non serve al client.
SUPABASE_SERVICE_ROLE_KEY=
